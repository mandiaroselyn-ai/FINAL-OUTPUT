{
  "version": 2,
  "name": "denr-workmate-backend",
  "builds": [
    {
      "src": "src/index.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.js"
    }
  ],
  "env": {
    "MONGO_URI": "@mongo_uri",
    "FRONTEND_URL": "@frontend_url",
    "JWT_SECRET": "@jwt_secret",
    "NODE_ENV": "production"
  },
  "buildCommand": "npm install",
  "outputDirectory": "."
}
