# MongoDB Connection String
# Local: mongodb://localhost:27017/denr-workmate
# Cloud: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/denr-workmate

# Frontend URL - Update this when deploying to Vercel
# Example: https://your-frontend-domain.vercel.app
FRONTEND_URL=http://localhost:5173

# Server Port
PORT=5000

# Node Environment (development or production)
NODE_ENV=development

# JWT Secret - Generate a secure token
JWT_SECRET=your_jwt_secret_here_change_in_production
